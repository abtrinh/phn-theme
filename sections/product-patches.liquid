</style>
{% assign discount_percentage = product.compare_at_price
| minus: product.price
| times: 100.0
| divided_by: product.compare_at_price
| round: 0 
%}
{% assign discount_change = product.compare_at_price
| minus: product.price
| money
%}
<section class="product">
  <div class="product__container container">
    <div class="product__galery">
      <div class="notDescTop">
        <h2 class="product__info__head">{{ product.metafields.product.basic_title }}</h2>
      </div>
      {%- assign gallery_images = product.metafields.product.images_set.value -%}
    {%- assign main_gallery_image = product.featured_image -%}
    {%- for img in gallery_images limit: 1 -%}
      {%- assign main_gallery_image = img -%}
    {%- endfor -%}
    <div class="product__galery__bigImage" id="full_image">
        <img
          class="product__galery__bigImage_image"
          src="{{ main_gallery_image | image_url: width: 1200, format: 'webp' }}"
          srcset="{{ main_gallery_image | image_url: width: 600, format: 'webp' }} 600w, {{ main_gallery_image | image_url: width: 900, format: 'webp' }} 900w, {{ main_gallery_image | image_url: width: 1200, format: 'webp' }} 1200w"
          sizes="(max-width: 990px) 100vw, 50vw"
          fetchpriority="high"
          alt="{{ main_gallery_image.alt | default: product.title }}"
        >
    </div>
      <div class="product__galery__smallImages">
        {% if gallery_images != blank %}
          {% for image in gallery_images %}
            <img
              class="product__galery__smallImages_image{% if forloop.first %} active{% endif %}"
              onclick="changePhoto();"
              src="{{ image | image_url: width: 100, height: 100, crop: 'center', format: 'webp' }}"
              data-src="{{ image | image_url: width: 1200, format: 'webp' }}"
              width="100"
              height="100"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              alt="{{ image.alt | default: product.title }}"
            >
          {% endfor %}
        {% else %}
          {% for image in product.images %}
            <img
              class="product__galery__smallImages_image{% if forloop.first %} active{% endif %}"
              onclick="changePhoto();"
              src="{{ image | image_url: width: 100, height: 100, crop: 'center', format: 'webp' }}"
              data-src="{{ image | image_url: width: 1200, format: 'webp' }}"
              width="100"
              height="100"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              alt="{{ image.alt | default: product.title }}"
            >
          {% endfor %}
        {% endif %}
      </div>
    </div>
