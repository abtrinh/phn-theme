{% assign discount_percentage = product.compare_at_price
| minus: product.price
| times: 100.0
| divided_by: product.compare_at_price
| round: 0 
%}
{% assign discount_change = product.compare_at_price
| minus: product.price
| money
%}

<!-- product selection -->
<section class="product">
  <div class="product__container container">
    <div class="product__galery">
      <div class="notDescTop">
        <h2 class="product__info__head">{{ product.metafields.product.basic_title }}</h2>
        <div class="product__info__review review">
          <span></span
          ><a href="javascript:void(0)" class="product__info__review--active"
            ><span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span
          ></a>
        </div>
      </div>
      <div class="product__galery__bigImage" id="full_image">
        <img
          class="product__galery__bigImage_image"
          src="{{ product.featured_image| img_url: 'grande'  }}"
        >
      </div>
      <div class="product__galery__smallImages">
        <img
          class="product__galery__smallImages_image active"
          onclick="changePhoto();"
          src="{{ product.featured_image| img_url: 'small'  }}"
          data-src="{{ product.featured_image| img_url: 'grande'  }}"
        >

        {% assign images_set = product.metafields.product.images_set.value %}
        {% for file in images_set %}
          
          <img
          class="product__galery__smallImages_image"
          onclick="changePhoto();"
          src="{{ file.preview_image |img_url  }}"
          data-src="{{ file | img_url: 'master'  }}"
        >
        {% endfor %}
        
        
      </div>
    </div>
    <div class="product__info cream_prod">
      <h2 class="product__info__head onlyDescTop">{{ product.metafields.product.basic_title }}</h2>
      <div class="product__info__review review onlyDescTop">
        <span></span
        ><a href="javascript:void(0)" class="product__info__review--active" data-name="Reviews"
          ><span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span
        ></a>
      </div>
      <div class="product__info-prices">
        <span class="current_price">$39.73</span><span class="not-discount">$46.74</span>
        <p class="save_text">You Save:<span id="precent">15%</span><span id="save-count">($5.96)</span></p>
        <span><div class="yotpo-widget-instance" data-yotpo-instance-id="1267418" data-yotpo-product-id="{{product.id}}" data-yotpo-cart-product-id="{{item.product.id}}" data-yotpo-section-id="{{template.name}}"></div></span>
      </div>
      <p class="product__info__text">Buy More and Save</p>
      <div class="product__info__changer">
        <button
          class="product__info--button active"
          onclick="changePhoto('button');"
          data-variant-id=""
          data-src="https://cdn.shopify.com/s/files/1/0555/4300/5364/files/photo_2024-04-08_17-36-49_2.jpg?v=1712704787"
        >
          <b class="weight">100 mg</b>
          <span class="patch_size">1 Roll-On</span>
          <span class="red_save">17.95 EACH</span>
        </button>
        <button
          class="product__info--button"
          onclick="changePhoto('button');"
          data-variant-id=""
          data-src="https://cdn.shopify.com/s/files/1/0555/4300/5364/files/2_75bc5947-a963-468d-9923-80f9fcc6ce43.png?v=1712704764">
          <!-- <div class="popular">
            <h4>Most Popular</h4>
          </div> -->
          <b class="weight">300 mg</b>
          <span class="patch_size">3 Roll-On’s</span>
          <span class="red_save">14.00 EACH</span>
        </button>
        <button
          class="product__info--button"
          onclick="changePhoto('button');"
          data-variant-id=""
          data-src="https://cdn.shopify.com/s/files/1/0555/4300/5364/files/3_0e089627-0838-4fa6-bbfb-2a09a2c070ee.png?v=1712704864">
          <div class="popular">
            <h4>Best Value</h4>
            
            <!-- <h4 >Sold Out</h4>
             -->
          </div>
          <b class="weight">500 mg</b>
          <span class="patch_size">5 Roll-On’s</span>
          <span class="red_save">12.00 EACH</span>
        </button>
        <select class="product__info__changer--select" style="display: none;">
          <option value="1 r. (100mg)">1 r. (100mg)</option>
          <option value="3 r. (300mg)">3 r. (300mg)</option>
          <option value="5 r. (500mg)">5 r. (500mg)</option>
        </select>
      </div>
      <div class="product__info--sub_box" id="product__info--sub_box">
        <h3>Sign Up For Autoship Today And Save Even More!</h3>
        <label class="product__info--input-area" for="one" style="display: none;">
          <input type="radio" name="subsc" value="false" id="one">
          One-time purchase
        </label>
        <label class="product__info--input-area selected" for="two">
          <input
            type="checkbox"
            class="custom-checkbox"
            name="subsc"
            value="true"
            id="two"
            onclick="checkboxClick(this)"
          >
          <label for="two"></label>
          <span id="subPrice" style="display: none;">25.61</span>
          <span id="subText" class="subText">Yes, Subscribe & Save!</span>
        </label>
      </div>
      <div class="product__info__qty">
        <input
          type="number"
          class="product__info__qty__input"
          step="1"
          min="1"
          value="1"
          inputmode="numeric"
          maxlength="2"
        >
        <input type="button" value="+" class="product__info__qty__plus">
        <input type="button" value="-" class="product__info__qty__minus">
      </div>
      <div class="product__info__addToCart">
        <button class="product__info__addToCart--button">Add To Cart</button>
      </div>
      <div class="product__info__seals">
        <img
          class="product__info__seals--image"
          src="//cdn.shopify.com/s/files/1/0555/4300/5364/files/trustBadges.png?v=1616801677"
        >
      </div>
      <div class="product__info__wrapper">
        <div class="product__info__wrapper__viewType">
          <button class="product__info__wrapper--active " data-name="Description">Description</button>
          <button class="product__info__wrapper--active active" data-name="Reviews">
            Reviews
          </button>
          <button class="product__info__wrapper--active" data-name="Ingredients">Ingredients</button>
          <button class="product__info__wrapper--active" data-name="Directions">Directions</button>
          <button class="product__info__wrapper--active" data-name="Analysis">Analysis Certificate</button>
        </div>
        <div class="product__info__wrapper__viewArea">
          <div id="descr" style="display: none;">
            {{ product.description }}
          </div>
          <div id="revie" style="display: block;">
            <div class="commentlist">
              <div class="yotpo yotpo-main-widget"
                  data-product-id="{{ product.id }}"
                  data-name="{{ product.title | escape }}"
                  data-url="{{ shop.url }}{{ product.url }}"
                  data-image-url="{{ product.featured_image | product_img_url: 'large' |replace: '?', '%3F' | replace: '&','%26'}}"
                  data-price="{{ variant.price | money_without_currency }}"
                  data-currency="{{ shop.currency }}"
                  data-description="{{ product.description | escape }}">
                </div>
              {% comment %} <script type="text/javascript">
                !function(){"use strict";!function(){if(void 0===window.OMNISEND_REVIEWS_SHOPIFY_LOADED){var e=(new Date).toISOString().slice(0,13);window.OMNISEND_REVIEWS_SHOPIFY_LOADED=!0;var t=document.createElement("script");t.type="text/javascript",t.async=!0,t.src="".concat("https://omnisnippet1.com/","reviews/reviews.js?v=").concat(e);var n=document.getElementsByTagName("script")[0];n.parentNode.insertBefore(t,n)}}()}();
                //# sourceMappingURL=shopify-product-reviews.js.map
              </script>
              <div id="omnisend-reviews-block"></div> {% endcomment %}
            </div>
          </div>
          <div id="video" style="display: none;text-align: center;"></div>
          <div id="ingre" style="display: none;">
            {{ product.metafields.product.ingredients| metafield_tag }}
          </div>
          <div id="direc" style="display: none;">
            {{ product.metafields.product.direction| metafield_tag }}
          </div>
          <div id="analy" style="display: none;">
            <a
              href="{{ product.metafields.custom.certificate_of_analysis.value.url }}"
              style="text-decoration:underline;color:#a758be;"
              target="_blank"
            >
              Certificate available on this link
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

