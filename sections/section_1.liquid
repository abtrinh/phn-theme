            <div class="section1__product-btn-block-arrow-body">Get Started Here</div>
            <div class="section1__product-btn-block-arrow-right"></div>
          </div>
          <a {% if section.settings.button_link_2 != blank %}href="{{ section.settings.button_link_2 }}" {% endif %} class="section1__product-btn-block-button">
            <img src="https://cdn.shopify.com/s/files/1/0555/4300/5364/files/shop_now_btn.png?v=1689897714" />
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Doubled Section",
    "settings": [
