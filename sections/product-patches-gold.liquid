{% assign discount_percentage = product.compare_at_price
| minus: product.price
| times: 100.0
| divided_by: product.compare_at_price
| round: 0 
%}
{% assign discount_change = product.compare_at_price
| minus: product.price
| money
%}

<section class="product">
