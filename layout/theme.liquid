<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_button }}">
  <meta name="ahrefs-site-verification" content="62c2287a229dcc50b7bbd4e0927b07b7b2d55de132a951766540c8ec08d84695">

  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  <link rel="preconnect" href="https://monorail-edge.shopifysvc.com">

  {%- comment -%} Redirect Logic {%- endcomment -%}
  {%- if template contains 'product' -%}
    <script>
      (function() {
        var h = window.location.pathname;
        var r = "";
        if (h.includes('pain-relief-patches') && h.includes('mg')) r = "/products/pain-relief-patches";
        else if (h.includes('hemp-relief-patches') && h.includes('mg')) r = "/products/hemp-relief-patches-gold";
        else if (h.includes('pain-relief-cream') && (h.includes('-x') || h.includes('auto'))) r = "/products/pain-relief-cream";
        else if (h.includes('immuni-z-patches-')) r = "/products/immuni-z-patches";
        else if (h.includes('movability-plus-patches-')) r = "/products/movability-plus-patches";
        else if (h.includes('calm-relax-nighttime-')) r = "/products/calm-relax";
        else if (h.includes('zoomie-sticks-')) r = "/products/zoomie-sticks";
        else if (h.includes('mobility-chews-')) r = "/products/mobility-chews";
        if (r) window.location.replace(r);
      })();
    </script>
  {%- endif -%}

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/5.4.5/css/swiper.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.css" />

  <link rel="stylesheet" href="{{ 'main.css' | asset_url }}">
  <link rel="stylesheet" href="{{ 'newstyle.css' | asset_url }}">
  <link rel="stylesheet" href="{{ 'hustle-popup.css' | asset_url }}">
  
  {%- assign header_font = settings.type_header_font -%}
  {%- assign base_font = settings.type_base_font -%}
  <link rel="preload" as="font" href="{{ header_font | font_url }}" type="font/woff2" crossorigin>
  <link rel="preload" as="font" href="{{ base_font | font_url }}" type="font/woff2" crossorigin>

  <title>{{ page_title }}</title>
  {%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}

  {% include 'social-meta-tags' %}
  {% include 'css-variables' %}

  <style>
    {{ header_font | font_face: font_display: 'swap' }}
    {{ base_font | font_face: font_display: 'swap' }}
    *,::after,::before{box-sizing:border-box}body{margin:0}body,html{background-color:var(--color-body)}body,button{font-size:calc(var(--font-size-base) * 1px);font-family:var(--font-stack-body);color:var(--color-text);line-height:1.5;-webkit-font-smoothing:antialiased}.border-bottom{border-bottom:1px solid var(--color-border)}.btn--link{background-color:transparent;border:0;margin:0;color:var(--color-text);text-align:left}.icon{display:inline-block;width:20px;height:20px;vertical-align:middle;fill:currentColor}.visually-hidden{position:absolute!important;overflow:hidden;clip:rect(0 0 0 0);height:1px;width:1px;margin:-1px;padding:0;border:0}li{list-style:none}.list--inline{padding:0;margin:0}.list--inline>li{display:inline-block;margin-bottom:0;vertical-align:middle}a{color:var(--color-text);text-decoration:none}.grid{list-style:none;margin:0;padding:0;margin-left:-30px}.grid::after{content:'';display:table;clear:both}@media only screen and (max-width:749px){.grid{margin-left:-22px}}.grid__item{float:left;padding-left:30px;width:100%}@media only screen and (max-width:749px){.grid__item{padding-left:22px}}.site-header{position:relative;background-color:var(--color-body)}@media only screen and (max-width:749px){.site-header{border-bottom:1px solid var(--color-border)}}.site-header__icons-wrapper{position:relative;display:flex;width:100%;align-items:center;justify-content:flex-end}.site-nav{position:relative;padding:0;text-align:center;margin:25px 0}.site-nav__link{display:block;white-space:nowrap}.site-header__mobile-nav{z-index:11;position:relative;background-color:var(--color-body)}@media only screen and (max-width:749px){.site-header__mobile-nav{display:flex;width:100%;align-items:center}}.main-content{opacity:0}
  </style>

  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}" type="text/css" media="print" onload="this.media='all';">

  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js" type="text/javascript"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/5.4.5/js/swiper.min.js" type="text/javascript"></script>

  <script>
    var theme = {
      moneyFormat: {{ shop.money_format | json }},
      strings: {
        addToCart: {{ 'products.product.add_to_cart' | t | json }},
        soldOut: {{ 'products.product.sold_out' | t | json }},
        unavailable: {{ 'products.product.unavailable' | t | json }}
      }
    };
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
  </script>

  {%- if request.page_type contains 'customers/' -%}
    <script src="{{ 'shopify_common.js' | shopify_asset_url }}" defer="defer"></script>
  {%- endif -%}

  <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'my-scripts.js' | asset_url }}"></script>
  <script src="{{ 'lazysizes.js' | asset_url }}" async="async"></script>

  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-TDHQFTL');</script>
  
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-722818689');
  </script>

  {{ content_for_header }}
  {% include 'pagefly-header' %}
  {% include 'pagefly-app-header' %}
</head>

<body class="template-{{ request.page_type | handle }}">
  {% section 'header' %}

  <div class="page-container drawer-page-content" id="PageContainer">
    <main class="main-content js-focus-hidden" id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    {% section 'footer' %}
  </div>

  {% include 'appstle-subscription-helper' %}
  {% include 'recent-box' %}

  <script>
    $(document).ready(function(){
      if(typeof cartUpdate === 'function') cartUpdate();
      
      const urlParams = new URLSearchParams(window.location.search);
      const clickId = urlParams.get('clickid');
      if (clickId) localStorage.setItem('clickid', clickId);
    });
  </script>
</body>
</html>