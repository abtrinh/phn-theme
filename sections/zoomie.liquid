<script>
  
  const percentDiscount = {{product.metafields.discount.discount}}

   var qty = 1;  
    document.querySelectorAll('.product__info--button').forEach((el,index)=> {
      el.dataset.variantId = _prod_array_base[index].id
    })
  var id = $('.product__info--button:first-child').data('variantId');  
  
  $(document).on('click','.product__info__addToCart--button',function(){
    data_set={id:id,quantity:qty}
    is_checked = $('#two').is(':checked');
    if(is_checked && _prodpercent[id]){
      data_set.id=_prodpercent[id].sub_id
      data_set['form_type']='product'
      data_set['selling_plan']=_prodpercent[id].selling_plan
    }
    
    $('.up-name').text(_prodbase_object_collect_set[id].name)
    console.log('DATA_set', data_set)
    $.ajax({
        type: 'POST', 
        url: '/cart/add.js',
        dataType: 'json', 
        data: data_set,
        success: function(){
			cartUpdate()
            open_upsell(upsell_array)
          	changeTotalOnPage()

        }
     })
    
  })
  $('.product__info--button').click(function(){
      $('.product__info--button').removeClass('active')
      $(this).addClass('active')
      id = $(this).data('variantId');
  })
  $('.product__info__qty input[type=button]').click(function(){
      var num = $('.product__info__qty__input').val()
      var symbol = $(this).val()
      symbol == '+'?num++:(num>1?num--:null)
      $('.product__info__qty__input').val(num)
      qty = num
  })
$('.product__info__wrapper--active,.product__info__review--active').click(function(){
      let item=$(this)
      var name = $(this).data('name').toLowerCase().slice(0,5)
      $('.product__info__wrapper--active').removeClass('active')
      $(this).addClass('active') 
      $('.product__info__wrapper__viewArea>div').hide()
      $('#'+name).show()
      if (typeof $(this).attr('aria-describedby') !== 'undefined' && $(this).attr('aria-describedby') !== false) {
		document.querySelector('#revie').scrollIntoView({behavior: 'smooth'});
      }
  })
  $('body *').click(function(e){
    if(e.target.dataset.link){
        window.location.href = e.target.dataset.link
    }
  })
  
  var elPrice = (_prod_array_base[0].price)
  var notDiscount = (_prod_array_base[0].compare)
  var saveCount = notDiscount - elPrice
  saveCount = saveCount.toFixed(2) 
  
  $('.current_price').html('$'+elPrice)
  $('.not-discount').html('$'+ notDiscount +'')
  $('#save-count').html('($'+saveCount+')')  
  $('#precent').html(percentDiscount[0]+'%')  
  document.querySelectorAll('.product__info--button').forEach((el,index)=> {
      el.addEventListener('click', function () {
        console.log(_prod_array_base[index]);
        var count_patches=$(el).find('.patch_size').text().split(' ')[0];
        var elPrice = _prod_array_base[index].price
        var notDiscount = _prod_array_base[index].compare                    
        var saveCount = notDiscount - elPrice
        saveCount = saveCount.toFixed(2)
        var perPatch=((elPrice)/count_patches).toFixed(2);
        $('.current_price').html('$'+elPrice)
        $('.not-discount').html('$'+ notDiscount +'')
        $('#save-count').html('($'+saveCount+')')
        $('#precent').html(percentDiscount[index]+'%') 
        console.log('SIZE', count_patches)
        console.log('_prodpercent', _prodpercent)
        if(_prodpercent[id]){
          $('#product__info--sub_box').show()
        }else{
          $('#product__info--sub_box').hide()
        }
        if($('#two').is(':checked')){
              setSubs(el,index) 
        }
  
      });
  })
  
  var currentMainPhoto = $('.product__info--button')[0].dataset.src
  function changePhoto(button){
    if (button){
        var src = event.currentTarget.dataset.src
        currentMainPhoto = src
        $('.product__galery__bigImage_image')[0].srcset = src
        $('.product__galery__smallImages_image').removeClass('active')
        $('.product__galery__smallImages_image')[0].classList.add('active')
    }else{
        if($('.product__galery__smallImages_image')[0] == event.target){
            $('.product__galery__bigImage_image')[0].srcset = currentMainPhoto
        }else{
          $('.product__galery__smallImages_image').removeClass('active')
          event.target.classList.add('active')
          var src = event.target.dataset.src
          $('.product__galery__bigImage_image')[0].srcset = src
        }
    }
  }
  
  function setSubs(el,index){
    
	const size=$(el).find('.patch_size').text().split(' ')[0]
    const textField = document.querySelector('#subText')
    price_off=(_prodpercent[id].compare-_prodpercent[id].a_price)
    price_subs=parseFloat(_prodpercent[id].a_price)
    switch (size) {
      case '1':
          monthlySave = _prodpercent[id].a_percent+'% ($'+(price_off).toFixed(2)+')';
          size_set=90
      break;
      case '3':
          monthlySave = _prodpercent[id].a_percent+'% ($'+(price_off).toFixed(2)+')';
      break;

      default:
          price = 0;
      break;
  }
    
    if($('#two').is(':checked')){
        textField.innerHTML = `Yes, Subscribe & Save! Automatically Receive<br><b>${size} Pack of Zoomies Sticks for $${price_subs.toFixed(2)}  + Free Shipping. Every 30 Days.</b> <br><span class="save_green">Total Monthly Savings: ${monthlySave}</span><br>Cancel Anytime. No Contracts!`
    }else{
      textField.innerHTML = 'Yes, Subscribe & Save!'
    }
    
  }
  
  function checkboxClick(e){
    
	setSubs($('*[data-variant-id="'+id+'"]'),0)

  }  

</script>
