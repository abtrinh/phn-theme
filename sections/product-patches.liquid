<span>
  <script>
    let _prodtemplate= {};
    let _prodpercent= {};
    let _prod_array_base=[];
    let _prod_price_setup= {};
    let _prodbase_object_collect={}
    let _prodbase_object_collect_set={}

    {% assign prod = ''%}
    {% for product in collections["patches-collection"].products %}
          metafields={{ product.metafields.product.description }}
          type='{{product.metafields.product.subscription_prod.value.variants[0].selling_plan_allocations.first.selling_plan.price_adjustments[0].value_type}}'
          arr_collect=[]
          metafields.map(test_in=>{
            test_arr=test_in.split(':')
            arr_collect[test_arr[0]]=test_arr[1]
          })
          _prodbase_object_collect
          if(type.toString()=='percentage'){
            _prodbase_object_collect={id:'{{product.variants[0].id}}',
                                      name:'{{product.title}}',
                                      handle:'{{product.handle}}',
                                      sub_id:'{{product.metafields.product.subscription_prod.value.variants[0].id}}',
                                      price:'{{product.price|money}}'.replace('$',''),
                                      compare:'{{product.compare_at_price|money}}'.replace('$',''),
                                      selling_plan:'{{product.metafields.product.subscription_prod.value.variants[0].selling_plan_allocations.first.selling_plan.id}}'
                                    }
        		_prodpercent[{{product.variants[0].id}}]={..._prodbase_object_collect, ...arr_collect}
          }else{
            _prodbase_object_collect={id:'{{product.variants[0].id}}',
                                 name:'{{product.title}}',
                                 handle:'{{product.handle}}',
                                 price:'{{product.price|money}}'.replace('$',''),
                                 compare:'{{product.compare_at_price|money}}'.replace('$',''),
                                 selling_plan:''}

          }
          _prodbase_object_collect_set[{{product.variants[0].id}}]={..._prodbase_object_collect, ...arr_collect}
          _prod_array_base.push({..._prodbase_object_collect, ...arr_collect})
    	  _prodtemplate[{{product.variants[0].id}}]={{product.variants[0].selling_plan_allocations.first.selling_plan.id}}
          _prod_price_setup[{{product.variants[0].id}}]={price:'{{product.price|money}}'.replace('$',''),compare:'{{product.compare_at_price|money}}'.replace('$','')}
      {% assign prodjson = product.variants[0].price | json %}
      {% assign prod_price = prod_price | append: prodjson | append: ',' %}
      {% assign prod = prod | append: prodjson | append: ',' %}
    {% endfor %}
  </script>
</span>
