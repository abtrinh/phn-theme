<button class="product__info--button" onclick="if (!window.__cfRLUnblockHandlers) return false; selectProd(2)">
<div class="popular">
<h4>Most Popular</h4>
</div>
<b class="weight">480 mg</b>
<span class="patch_size">60 PATCHES</span>
<span class="red_save">save 25%</span>
</button>
  
<button class="product__info--button" onclick="if (!window.__cfRLUnblockHandlers) return false; selectProd(3)">
<div class="popular">
<h4>Best Value</h4>
</div>
<b class="weight">960 mg</b>
<span class="patch_size">120 PATCHES</span>
<span class="red_save">save 37%</span>
