      </div>
      <div class="section1__product-image">
         <a {% if section.settings.button_link_2 != blank %}href="{{ section.settings.button_link_2 }}" {% endif %} >
            <img src="https://cdn.shopify.com/s/files/1/0555/4300/5364/files/sticks.jpg?v=1689892849" alt="Calm & Relax" />
