<section class="header">
  <div class='banner_top'>
    <div class="header__banner">
      <a href="/" class="banner_bg"></a>
    </div>
  </div>

  <div class='site_nav_sticky sticky'>
    <div class='item_menu menu-left'>
      {% render 'site-nav', linklist: section.settings.main_linklist, linklistmobile: section.settings.main_linklist_mob, wrapper_class: 'site-nav--centered' %}
    </div>
    
    <div class='item_menu menu-center'>
      <div class="header__container">
        <div class="header__logo">
          <a href="/" class="header__link header__link--active">
            <img src="https://cdn.shopify.com/s/files/1/0555/4300/5364/files/logos_6d52dbae-48ca-4352-a543-089d768a7ca4.png?v=1689550352" 
                 class="header__link_img" 
                 width="180" 
                 height="65" 
                 alt="{{ shop.name | escape }}">
          </a>
        </div>
      </div>
    </div>

    <div class='item_menu menu-right'>
      <div class="header__cart">
        <div class="header_info__text">
          Need Help? Call or Text (970) 718-2801
        </div>
        <div class="header__menu">
          <a href="/cart" class="cart_link">
            <img src="https://cdn.shopify.com/s/files/1/0555/4300/5364/files/bag_black.svg?v=1688878524" 
                 class="header__svg header__svg--active" 
                 width="24" 
                 height="24" 
                 alt="Cart">
            <div class="header__menu_count" data-cart-count-bubble data-cart-count></div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  section.header {
    display: block;
    width: 100%;
  }

  .site_nav_sticky {
    position: relative;
    display: block;
    background: #ffffff;
    padding: 10px 20px;
    height: 85px;
    border-bottom: 1px solid #eee;
    z-index: 10;
  }

  .menu-left {
    float: left;
    display: block;
  }

  .menu-center {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    width: 200px;
  }

  .menu-right {
    float: right;
    display: block;
    margin-top: 15px;
  }

  .site_nav_sticky ul, 
  .site_nav_sticky .site-nav {
    display: block;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site_nav_sticky li {
    display: inline-block;
    margin-right: 20px;
  }

  .site_nav_sticky a, 
  .site_nav_sticky .site-nav__link {
    color: #000000 !important;
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
    line-height: 65px;
  }

  .header__link_img {
    display: block;
    margin: 0 auto;
  }

  .header .banner_bg {
    background-image:url({{section.settings.header_desktop | img_url: '1000x70'}});
    width:1000px;
    height:70px;
    background-size:contain;
    display:block;
    margin: 0 auto;
  }

  .header__cart {
    display: block;
    text-align: right;
  }

  .header_info__text {
    display: inline-block;
    vertical-align: middle;
    color: #000;
    font-size: 13px;
    margin-right: 10px;
  }

  .header__menu {
    display: inline-block;
    vertical-align: middle;
  }

  @media(max-width:1240px) {
    .header .banner_bg {
      background-image:url({{section.settings.header_tablet | img_url: '600x70'}});
      width:600px;
      height:70px;
    }      
  }

  @media(max-width:1024px) {
    .header_info__text { display: none; }
  }

  @media(max-width:830px) {
    .header .banner_bg {
      background-image:url({{section.settings.header_mobile | img_url: '500x140'}});
      width: 258px;
      height: 72px;
      margin-left: 10px;
    }
    .menu-left { display: none; }
    .menu-center { left: 10px; transform: translateY(-50%); width: auto; }
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "header", "content": "Images for Header" },
    { "type": "image_picker", "id": "header_desktop", "label": "Header Desktop Image" },
    { "type": "image_picker", "id": "header_tablet", "label": "Header Tablet Image" },
    { "type": "image_picker", "id": "header_mobile", "label": "Header Mobile Image" },
    { "type": "header", "content": "Menu Settings" },
    { "type": "link_list", "id": "main_linklist", "label": "Menu", "default": "main-menu" },
    { "type": "link_list", "id": "main_linklist_mob", "label": "Menu Mobile", "default": "main-menu" }
  ]
}
{% endschema %}