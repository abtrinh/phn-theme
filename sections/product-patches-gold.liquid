        >
        {% assign images_set = product.metafields.product.images_set.value %}
        {% for file in images_set %}
          
          <img
          class="product__galery__smallImages_image"
          onclick="changePhoto();"
          src="{{ file.preview_image |img_url  }}"
          data-src="{{ file | img_url: 'master'  }}"
